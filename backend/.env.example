# Server
PORT=5000
NODE_ENV=development

# Auth
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Database (SQLite file path, relative to backend/)
DB_PATH=./db/tracker.db

# Business rules
OVERDUE_THRESHOLD_DAYS=5

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=5

# Frontend origin (for CORS)
FRONTEND_URL=http://localhost:3000

# Email (any free SMTP provider works: Gmail App Password, Brevo/Sendinblue,
# Mailtrap for dev/testing, or Ethereal for a fully fake inbox with no signup)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
MAIL_FROM="Society Maintenance <no-reply@society.local>"

# If true, emails are only logged to console instead of actually sent
# (useful for local dev without SMTP credentials)
MAIL_DRY_RUN=true
